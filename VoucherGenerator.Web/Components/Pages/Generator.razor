@page "/"
@rendermode InteractiveServer
@inject IVoucherService VoucherService
@inject IJSRuntime JS

<PageTitle>Generate Vouchers</PageTitle>

<!-- ======= SCREEN ======= -->
<div class="generator-page no-print">
    <h1 class="page-title">Generate Vouchers</h1>

    <section class="card generator-card config-card">
        <div class="card-header-row">
            <span class="card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
                    <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
                    <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
                </svg>
            </span>
            <span class="card-title">Configuration</span>
        </div>

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label" for="countInput">Number of Vouchers</label>
                <input id="countInput" type="number" class="form-input" @bind="Count" min="1" max="1000" placeholder="50" />
                <small class="form-hint">Between 1 and 1000</small>
            </div>
            <div class="form-group">
                <label class="form-label" for="digitsInput">Digits per Code</label>
                <input id="digitsInput" type="number" class="form-input" @bind="Digits" min="1" max="50" placeholder="12" />
                <small class="form-hint">Between 1 and 50</small>
            </div>
            <div class="form-group">
                <label class="form-label" for="networkInput">Network Name</label>
                <input id="networkInput" type="text" class="form-input" @bind="NetworkName" placeholder="MTN" />
                <small class="form-hint">Provider or network identifier</small>
            </div>
            <div class="form-group">
                <label class="form-label" for="typeInput">Voucher Type</label>
                <input id="typeInput" type="text" class="form-input" @bind="VoucherType" placeholder="Data" />
                <small class="form-hint">Category of this batch</small>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <span>@ErrorMessage</span>
            </div>
        }

        <div class="panel-footer action-bar">
            <button class="btn btn-primary" @onclick="GenerateVouchers" disabled="@IsGenerating">
                @if (IsGenerating)
                {
                    <span class="spinner"></span>
                    <span>Generating...</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                    </svg>
                    <span>Generate</span>
                }
            </button>
            <button class="btn btn-soft" @onclick="ClearAll" disabled="@(GeneratedNumbers.Count == 0 && string.IsNullOrWhiteSpace(NetworkName) && string.IsNullOrWhiteSpace(VoucherType) && Count is null && Digits is null)">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                    <path d="M10 11v6"></path>
                    <path d="M14 11v6"></path>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                </svg>
                <span>Clear</span>
            </button>
        </div>
    </section>

    @if (GeneratedNumbers.Count > 0)
    {
        <section class="card generator-card">
            <div class="card-header-row header-with-action">
                <div class="header-copy-wrap">
                    <span class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                    </span>
                    <span class="card-title card-title-strong">Generated Codes (@GeneratedNumbers.Count)</span>
                </div>
                <button class="btn-icon" title="Copy all codes" @onclick="CopyAllCodes">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
            <div class="numbers-box compact-codes-box">
                @foreach (var entry in GeneratedNumbers.Select((num, index) => new { num, index }))
                {
                    <button type="button" class="number-chip" @onclick="() => CopyCode(entry.num)" title="Click to copy">
                        <span class="number-chip-index">@(entry.index + 1)</span>
                        <span class="number-chip-value">@entry.num</span>
                    </button>
                }
            </div>
            <div class="inline-note">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                <span>Click any code to copy it</span>
            </div>
        </section>

        <section class="card generator-card">
            <div class="card-header-row header-with-action">
                <div class="header-copy-wrap">
                    <span class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="8" y1="6" x2="21" y2="6"></line>
                            <line x1="8" y1="12" x2="21" y2="12"></line>
                            <line x1="8" y1="18" x2="21" y2="18"></line>
                            <line x1="3" y1="6" x2="3.01" y2="6"></line>
                            <line x1="3" y1="12" x2="3.01" y2="12"></line>
                            <line x1="3" y1="18" x2="3.01" y2="18"></line>
                        </svg>
                    </span>
                    <span class="card-title card-title-strong">Voucher Details</span>
                </div>
                <button class="btn-icon" title="Copy all details" @onclick="CopyAllDetails">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
            <div class="voucher-strings-box detail-list-box">
                @foreach (var entry in GeneratedNumbers.Select((num, index) => new { num, index }))
                {
                    <div class="voucher-string-line">
                        <span class="line-index">@(entry.index + 1)</span>
                        <span class="vsl-text">Network Name: @NetworkName, Voucher Number: @entry.num, Voucher Pass: @entry.num, Voucher Type: @VoucherType</span>
                        <button class="copy-btn" title="Copy this line" @onclick='() => CopyLine($"Network Name: {NetworkName}, Voucher Number: {entry.num}, Voucher Pass: {entry.num}, Voucher Type: {VoucherType}")'>
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                            </svg>
                        </button>
                    </div>
                }
            </div>
        </section>

        <section class="card generator-card voucher-actions-card">
            <div class="action-row">
                <div class="action-group action-group-left">
                    @if (!IsSaved)
                    {
                        <button class="btn btn-success" @onclick="SaveVouchers" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <span class="spinner"></span>
                                <span>Saving...</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                    <polyline points="7 3 7 8 15 8"></polyline>
                                </svg>
                                <span>Save to History</span>
                            }
                        </button>
                    }
                    else
                    {
                        <span class="saved-badge">Saved to History</span>
                    }
                </div>

                <div class="action-group action-group-right">
                    <button class="btn btn-ghost" @onclick="PrintVouchers">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 6 2 18 2 18 9"></polyline>
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                            <rect x="6" y="14" width="12" height="8"></rect>
                        </svg>
                        <span>Print</span>
                    </button>
                    <button class="btn btn-ghost" @onclick="DownloadPdf">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        <span>Download PDF</span>
                    </button>
                </div>
            </div>

            <small class="form-hint action-hint">Save this batch to your voucher history</small>
        </section>

        <section class="print-preview-shell">
            <div class="preview-title">Print Preview (shown when printing)</div>
            <div class="print-preview-card">
                <div class="preview-meta-row">
                    <span class="preview-meta-item preview-meta-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 6 2 18 2 18 9"></polyline>
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                            <rect x="6" y="14" width="12" height="8"></rect>
                        </svg>
                    </span>
                    <span class="preview-meta-item preview-meta-network"><span class="preview-meta-label">Network:</span><span class="preview-meta-value">@NetworkName</span></span>
                    <span class="preview-meta-divider">|</span>
                    <span class="preview-meta-item preview-meta-type"><span class="preview-meta-label">Type:</span><span class="preview-meta-value">@VoucherType</span></span>
                    <span class="preview-meta-divider">|</span>
                    <span class="preview-meta-item preview-meta-generated"><span class="preview-meta-label">Generated:</span><span class="preview-meta-value">@GeneratedAt?.ToString("yyyy-MM-dd HH:mm")</span></span>
                    <span class="preview-meta-divider">|</span>
                    <span class="preview-meta-item preview-meta-count"><span class="preview-meta-label">Count:</span><span class="preview-meta-value">@GeneratedNumbers.Count</span></span>
                </div>

                <div class="preview-grid">
                    @foreach (var num in GeneratedNumbers.Take(8))
                    {
                        <div class="preview-voucher-card">
                            <div class="preview-voucher-number">@num</div>
                            <div class="preview-voucher-meta">Network Name: @NetworkName</div>
                            <div class="preview-voucher-meta">Voucher Type: @VoucherType</div>
                        </div>
                    }
                </div>

                @if (GeneratedNumbers.Count > 8)
                {
                    <div class="preview-more">...and @(GeneratedNumbers.Count - 8) more vouchers</div>
                }
            </div>
        </section>
    }
</div>

<!-- ======= PRINT AREA ======= -->
@if (GeneratedNumbers.Count > 0)
{
    <div class="print-area" id="printArea">
        <div class="print-preview-card print-preview-card-export">
            <div class="preview-meta-row print-header">
                <span class="preview-meta-item preview-meta-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 6 2 18 2 18 9"></polyline>
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                        <rect x="6" y="14" width="12" height="8"></rect>
                    </svg>
                </span>
                <span class="preview-meta-item preview-meta-network"><span class="preview-meta-label">Network:</span><span class="preview-meta-value">@NetworkName</span></span>
                <span class="preview-meta-divider">|</span>
                <span class="preview-meta-item preview-meta-type"><span class="preview-meta-label">Type:</span><span class="preview-meta-value">@VoucherType</span></span>
                <span class="preview-meta-divider">|</span>
                <span class="preview-meta-item preview-meta-generated"><span class="preview-meta-label">Generated:</span><span class="preview-meta-value">@GeneratedAt?.ToString("yyyy-MM-dd HH:mm")</span></span>
                <span class="preview-meta-divider">|</span>
                <span class="preview-meta-item preview-meta-count"><span class="preview-meta-label">Count:</span><span class="preview-meta-value">@GeneratedNumbers.Count</span></span>
            </div>

            <div class="preview-grid voucher-grid">
            @foreach (var num in GeneratedNumbers)
            {
                <div class="preview-voucher-card voucher-card">
                    <div class="preview-voucher-number vc-number">@num</div>
                    <div class="preview-voucher-meta vc-network">Network Name: @NetworkName</div>
                    <div class="preview-voucher-meta vc-type">Voucher Type: @VoucherType</div>
                </div>
            }
            </div>
        </div>
    </div>
}
