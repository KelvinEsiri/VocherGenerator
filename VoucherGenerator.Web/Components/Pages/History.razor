@page "/history"
@rendermode InteractiveServer
@inject IVoucherService VoucherService

<PageTitle>Voucher History</PageTitle>

<div class="history-page no-print">
    <h1 class="page-title">Voucher History</h1>

    <section class="card generator-card history-search-card">
        <div class="card-header-row">
            <span class="card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </span>
            <span class="card-title">Search</span>
        </div>
        <div class="search-panel">
            <div class="search-row">
            <input type="text"
                   class="form-input search-input"
                   @bind="SearchQuery"
                   @bind:event="oninput"
                   @onkeyup="OnSearchKeyUp"
                   placeholder="Search by voucher number, network, type, or valid till..." />
                <button class="btn btn-primary" @onclick="Search">Search</button>
                <button class="btn btn-soft" @onclick="ClearSearch">Clear</button>
            </div>
            <small class="form-hint">Search by voucher number, network name, voucher type, or valid till</small>
        </div>
    </section>

    @if (IsLoading)
    {
        <div class="loading-text">Loading records...</div>
    }
    else if (Vouchers.Count == 0)
    {
        <div class="card generator-card history-empty-card">
            <div class="empty-state">
            <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                </svg>
            </div>
            @if (!string.IsNullOrWhiteSpace(SearchQuery))
            {
                <p>No vouchers matched <strong>"@SearchQuery"</strong>.</p>
                <p><button class="btn-link-inline" @onclick="ClearSearch">Clear search</button> to see all records.</p>
            }
            else
            {
                <p>No vouchers saved yet.</p>
                <p>Generate and save vouchers to see them here.</p>
            }
            </div>
        </div>
    }
    else
    {
        <section class="card generator-card history-results-card">
            <div class="card-header-row history-results-header">
                <div class="header-copy-wrap">
                    <span class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </span>
                    <span class="card-title card-title-strong">Saved Vouchers</span>
                </div>
                <span class="result-count">@Vouchers.Count result(s)</span>
            </div>

            <div class="table-wrapper">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Voucher Number</th>
                            <th>Network Name</th>
                            <th>Voucher Type</th>
                            <th>Valid Till</th>
                            <th>Generated At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in PagedVouchers.Select((voucher, index) => new { voucher, index }))
                        {
                            <tr>
                                <td>
                                    <span class="history-index-badge">@((CurrentPage - 1) * PageSize + entry.index + 1)</span>
                                </td>
                                <td>
                                    <div class="history-voucher-number">@entry.voucher.VoucherNumber</div>
                                    @* <div class="history-record-id">Record ID: @entry.voucher.Id</div> *@
                                </td>
                                <td><span class="history-tag network-pill">@entry.voucher.NetworkName</span></td>
                                <td><span class="history-tag type-pill">@entry.voucher.VoucherType</span></td>
                                <td><span class="history-tag valid-pill">@entry.voucher.ValidTill</span></td>
                                <td class="date-col">@entry.voucher.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="history-pagination-bar">
                    <span class="history-page-summary">Showing @PageStart to @PageEnd of @Vouchers.Count</span>
                    <div class="history-pagination-controls">
                        <button class="btn btn-soft pagination-btn" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">Previous</button>
                        @foreach (var pageNumber in VisiblePages)
                        {
                            <button class="btn @(pageNumber == CurrentPage ? "btn-primary" : "btn-soft") pagination-btn" @onclick="() => GoToPage(pageNumber)">@(pageNumber)</button>
                        }
                        <button class="btn btn-soft pagination-btn" @onclick="NextPage" disabled="@(CurrentPage == TotalPages)">Next</button>
                    </div>
                </div>
            }
        </section>
    }
</div>
