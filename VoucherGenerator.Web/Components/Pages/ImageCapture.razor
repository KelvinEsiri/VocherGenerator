@page "/image-capture"
@rendermode InteractiveServer
@inject IImageCaptureService ImageCaptureService
@inject IJSRuntime JS

<PageTitle>Image Capture</PageTitle>

<div class="history-page no-print image-capture-page">
    <h1 class="page-title generator-title">Image Capture</h1>

    <section class="card generator-card image-upload-card">
        <div class="card-header-row">
            <span class="card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                    <circle cx="12" cy="13" r="3"/>
                </svg>
            </span>
            <span class="card-title">Capture Image</span>
        </div>

        <div class="search-panel">
            <div class="form-group image-filename-group">
                <label class="form-label" for="imageFileName">Filename</label>
                <input id="imageFileName" type="text" class="form-input" @bind="FileName" placeholder="e.g. front-id-card" />
                <small class="form-hint">Stored with the image in the database</small>
            </div>

            @* ── File upload – commented out; using camera capture instead ─────────────
            <div class="form-group">
                <label class="form-label" for="imagePicker">Image File</label>
                <InputFile id="imagePicker" class="form-input" OnChange="OnFileSelected" accept="image/*" />
                <small class="form-hint">Browser image formats. Max 10 MB.</small>
            </div>
            ── *@

            <div class="camera-area @(IsCameraActive ? "camera-area--live" : string.Empty)">
                @* Video is always in the DOM so JS can attach the stream immediately *@
                <video id="cameraVideo" autoplay playsinline muted class="camera-video"></video>
                <canvas id="cameraCanvas" style="display:none"></canvas>

                @if (!IsCameraActive && !string.IsNullOrEmpty(CapturedDataUrl))
                {
                    <img src="@CapturedDataUrl" class="camera-snapshot-img" alt="Captured frame" />
                }

                @if (!IsCameraActive && string.IsNullOrEmpty(CapturedDataUrl))
                {
                    <div class="camera-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                            <circle cx="12" cy="13" r="3"/>
                        </svg>
                        <p>Click <strong>Start Camera</strong> to begin.</p>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="error-message image-feedback">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <span>@ErrorMessage</span>
                </div>
            }

            <div class="panel-footer action-bar">
                @if (!IsCameraActive && string.IsNullOrEmpty(CapturedDataUrl))
                {
                    <button class="btn btn-slate" @onclick="StartCameraAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                            <circle cx="12" cy="13" r="3"/>
                        </svg>
                        <span>Start Camera</span>
                    </button>
                }
                @if (IsCameraActive)
                {
                    <button class="btn btn-primary" @onclick="CaptureFrameAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <span>Capture</span>
                    </button>
                    <button class="btn btn-soft" @onclick="StopCameraAsync">
                        <span>Stop Camera</span>
                    </button>
                }
                @if (!string.IsNullOrEmpty(CapturedDataUrl) && !IsCameraActive)
                {
                    <button class="btn btn-success" @onclick="SaveImage" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                <polyline points="7 3 7 8 15 8"></polyline>
                            </svg>
                            <span>Save Image</span>
                        }
                    </button>
                    <button class="btn btn-soft" @onclick="ClearCapture">
                        <span>Retake</span>
                    </button>
                }
            </div>
        </div>
    </section>

    <section class="card generator-card history-results-card image-results-card">
        <div class="card-header-row history-results-header">
            <div class="header-copy-wrap">
                <span class="card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </span>
                <span class="card-title card-title-strong">Saved Images</span>
            </div>
            <div class="image-results-meta">
                <span class="image-table-hint">Click <strong>Preview</strong> to open image</span>
                <span class="result-count">@FilteredCount result(s)</span>
            </div>
        </div>

        <div class="search-panel image-search-panel">
            <div class="search-row image-search-row">
                <input type="text"
                       class="form-input search-input"
                       @bind="SearchQuery"
                       @bind:event="oninput"
                       placeholder="Search filenames..." />
                <button class="btn btn-soft" @onclick="ClearSearch" disabled="@string.IsNullOrWhiteSpace(SearchQuery)">Clear</button>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="loading-text">Loading records...</div>
        }
        else if (Images.Count == 0)
        {
            <div class="empty-state image-empty-state">
                <p>No images saved yet.</p>
                <p>Capture and save images to see them here.</p>
            </div>
        }
        else if (FilteredCount == 0)
        {
            <div class="empty-state image-empty-state">
                <p>No image matched <strong>"@SearchQuery"</strong>.</p>
                <p>Try a different filename keyword.</p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Thumb</th>
                            <th>Filename</th>
                            <th>Saved At</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in PagedImages.Select((image, index) => new { image, index }))
                        {
                            <tr class="@(entry.image.Id == SelectedImageId ? "image-row-selected" : string.Empty)">
                                <td><span class="history-index-badge">@((CurrentPage - 1) * PageSize + entry.index + 1)</span></td>
                                <td>
                                    @if (entry.image.ThumbnailData.Length > 0)
                                    {
                                        <img src="@BuildThumbnailDataUrl(entry.image)" alt="Thumbnail of @entry.image.FileName" class="image-table-thumb" />
                                    }
                                    else
                                    {
                                        <span class="image-thumb-fallback">N/A</span>
                                    }
                                </td>
                                <td><strong>@entry.image.FileName</strong></td>
                                <td class="date-col">@entry.image.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="image-action-group">
                                        <button class="btn btn-soft" @onclick="() => SelectImage(entry.image.Id)">Preview</button>
                                        <button class="btn btn-outline" @onclick="() => PromptDelete(entry.image.Id, entry.image.FileName)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PaginationBar CurrentPage="@CurrentPage"
                           TotalPages="@TotalPages"
                           PageStart="@PageStart"
                           PageEnd="@PageEnd"
                           TotalCount="@FilteredCount"
                           OnPrevious="PreviousPage"
                           OnNext="NextPage"
                           OnGoTo="GoToPage" />
        }
    </section>

    <AppModal IsOpen="@IsDeleteConfirmOpen"
              Eyebrow="Delete Image"
              Title="@($"Delete {PendingDeleteFileName}?")"
              AriaLabel="Delete confirmation"
              DialogClass="image-delete-modal"
              OnClose="CancelDelete">
        <ChildContent>
            <p class="image-delete-copy">This action is permanent and cannot be undone.</p>
        </ChildContent>
        <FooterContent>
            <div class="image-delete-footer">
                <button class="btn btn-soft" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-outline image-delete-confirm-btn" @onclick="ConfirmDeleteAsync" disabled="@IsDeleting">
                    @if (IsDeleting)
                    {
                        <span class="spinner"></span>
                        <span>Deleting...</span>
                    }
                    else
                    {
                        <span>Delete</span>
                    }
                </button>
            </div>
        </FooterContent>
    </AppModal>

    <AppModal IsOpen="@IsPreviewOpen"
              Eyebrow="Image Preview"
              Title="@SelectedImageFileName"
              AriaLabel="Image preview"
              DialogClass="image-preview-modal"
              OnClose="ClosePreview">
        <ChildContent>
            <img src="@SelectedImageDataUrl" alt="Preview of @SelectedImageFileName" class="captured-image-preview" />
        </ChildContent>
        <FooterContent>
            <button class="btn btn-soft" @onclick="ClosePreview">Close Preview</button>
        </FooterContent>
    </AppModal>
</div>
